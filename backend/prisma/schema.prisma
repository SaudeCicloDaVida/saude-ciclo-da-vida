generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id          String       @id @default(uuid())
  name        String
  type        OrgType      @default(HOSPITAL)
  slug        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  panicAlerts PanicAlert[]
  users       User[]
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  password          String
  name              String?
  photoUrl          String?
  role              UserRole           @default(PACIENTE)
  organizationId    String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  lastLatitude      Float?
  lastLongitude     Float?
  lastSeenAt        DateTime?
  appointments      Appointment[]
  auditLogs         AuditLog[]         @relation("UserActions")
  carePlans         CarePlan[]
  caringFor         CareRelationship[] @relation("CaregiverRelation")
  caredBy           CareRelationship[] @relation("PatientRelation")
  emergencyContacts EmergencyContact[]
  medications       Medication[]
  pairingTokens     PairingToken[]
  panicAlerts       PanicAlert[]
  profile           PatientProfile?
  personalEvents    PersonalEvent[]
  organization      Organization?      @relation(fields: [organizationId], references: [id])
}

model PatientProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  bloodType       String?
  height          Float?
  weight          Float?
  allergies       String?
  chronicDiseases String?
  healthInsurance String?
  obs             String?
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CareRelationship {
  id          String   @id @default(uuid())
  caregiverId String
  patientId   String
  permissions Json
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  caregiver   User     @relation("CaregiverRelation", fields: [caregiverId], references: [id])
  patient     User     @relation("PatientRelation", fields: [patientId], references: [id])

  @@unique([caregiverId, patientId])
}

model PairingToken {
  id        String   @id @default(uuid())
  code      String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model EmergencyContact {
  id           String @id @default(uuid())
  userId       String
  name         String
  phone        String
  relationship String
  priority     Int    @default(1)
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PanicAlert {
  id             String        @id @default(uuid())
  userId         String
  organizationId String?
  latitude       Float
  longitude      Float
  batteryLevel   Int?
  resolved       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
}

model Medication {
  id                  String               @id @default(uuid())
  userId              String
  name                String
  activeIngredient    String?
  dosage              String
  type                String               @default("pill")
  instructions        String?
  stockCurrent        Int                  @default(0)
  stockMin            Int                  @default(5)
  prescriptionDate    DateTime?
  prescriptionExpires DateTime?
  photoUrl            String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules           MedicationSchedule[]
}

model MedicationSchedule {
  id           String      @id @default(uuid())
  medicationId String
  time         String
  frequency    String?
  logs         IntakeLog[]
  medication   Medication  @relation(fields: [medicationId], references: [id], onDelete: Cascade)
}

model IntakeLog {
  id           String             @id @default(uuid())
  scheduleId   String
  status       String
  takenAt      DateTime           @default(now())
  scheduledFor DateTime
  schedule     MedicationSchedule @relation(fields: [scheduleId], references: [id])
}

model Clinic {
  id           String        @id @default(uuid())
  name         String
  address      String
  phone        String?
  latitude     Float
  longitude    Float
  appointments Appointment[]
}

model Professional {
  id           String        @id @default(uuid())
  name         String
  specialty    String
  registry     String?
  phone        String?
  appointments Appointment[]
  carePlans    CarePlan[]
}

model Appointment {
  id             String        @id @default(uuid())
  userId         String
  date           DateTime
  clinicId       String?
  professionalId String?
  specialty      String?
  notes          String?
  status         String        @default("SCHEDULED")
  clinic         Clinic?       @relation(fields: [clinicId], references: [id])
  professional   Professional? @relation(fields: [professionalId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
}

model PersonalEvent {
  id          String    @id @default(uuid())
  userId      String
  title       String
  description String?
  category    String
  startAt     DateTime
  endAt       DateTime?
  location    String?
  isDone      Boolean   @default(false)
  user        User      @relation(fields: [userId], references: [id])
}

model CareTemplate {
  id        String  @id @default(uuid())
  title     String
  category  String
  objective String?
  content   Json
  isPublic  Boolean @default(false)
  createdBy String?
}

model CarePlan {
  id             String        @id @default(uuid())
  userId         String
  title          String
  category       String
  content        Json
  startDate      DateTime      @default(now())
  endDate        DateTime?
  professionalId String?
  active         Boolean       @default(true)
  professional   Professional? @relation(fields: [professionalId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String?
  action    String
  targetId  String?
  entity    String
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  actor     User?    @relation("UserActions", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([targetId])
  @@index([action])
}

enum OrgType {
  HOSPITAL
  CLINIC
  LABORATORY
  ONG
}

enum UserRole {
  ADMIN
  PACIENTE
  FAMILIAR
  PROFISSIONAL
}
